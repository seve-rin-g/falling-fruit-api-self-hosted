# =============================================================================
# Falling Fruit API — Production Environment Variables
# =============================================================================
# This is the template for /etc/falling-fruit-api/.env on your EC2 instance.
# The setup.sh script creates this file at /etc/falling-fruit-api/.env
#
# IMPORTANT: After setup, edit this file with your actual values:
#   sudo nano /etc/falling-fruit-api/.env
#   sudo systemctl restart falling-fruit-api
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

NODE_ENV=production

# API port — ensure this matches your EC2 Security Group inbound rules
PORT=3300

# API base path prefix
API_BASE=/api/0.3

# -----------------------------------------------------------------------------
# Database — PostgreSQL + PostGIS
# -----------------------------------------------------------------------------
# LOCAL POSTGRES (default after setup.sh):
DB=postgres://ffuser:CHANGE_THIS_TO_SECURE_PASSWORD@localhost:5432/falling_fruit

# AWS RDS (alternative — comment out the line above and uncomment this):
# DB=postgres://ffuser:CHANGE_THIS_TO_RDS_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/falling_fruit

# -----------------------------------------------------------------------------
# Security — CHANGE ALL OF THESE BEFORE GOING LIVE
# -----------------------------------------------------------------------------
# Generate JWT_SECRET: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS

# Generate API_KEY: openssl rand -hex 32
# This is the key your application must send in the x-api-key header
API_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_API_KEY

# -----------------------------------------------------------------------------
# reCAPTCHA (Optional — leave empty to disable for self-hosted use)
# -----------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# AWS S3 Photo Storage (Optional)
# -----------------------------------------------------------------------------
# Required for photo upload functionality
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Email via Postmark (Optional)
# -----------------------------------------------------------------------------
# Required for user registration confirmation and password reset emails
POSTMARK_API_TOKEN=
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Performance & Limits
# -----------------------------------------------------------------------------
# Maximum locations per API request
MAX_LIMIT=1000

# Disable verbose SQL logging in production
LOG_QUERIES=false

# -----------------------------------------------------------------------------
# CORS — Origins allowed to call this API
# -----------------------------------------------------------------------------
# Set to your application's domain(s), or * for any origin
# Example: https://myapp.com,https://www.myapp.com
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Node.js Performance
# -----------------------------------------------------------------------------
# Set max memory for Node.js (adjust based on your EC2 instance size)
# t3.micro (1 GB):  512
# t3.small (2 GB):  1024
# t3.medium (4 GB): 2048
NODE_OPTIONS=--max-old-space-size=512
