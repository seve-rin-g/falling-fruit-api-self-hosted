# =============================================================================
# Falling Fruit API — Local Development Environment Variables
# =============================================================================
# Copy this file to falling-fruit-api/.env before running Docker or local dev.
# NEVER commit the .env file (it's in .gitignore).
#
# Usage:
#   cp .env.example falling-fruit-api/.env
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Environment (development | production | test)
NODE_ENV=development

# API server port
PORT=3300

# API base path prefix
API_BASE=/api/0.3

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# For Docker Compose: use "db" as the hostname (Docker service name)
# For local dev without Docker: use "localhost"
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE

DB=postgres://ffuser:ffpassword@db:5432/falling_fruit

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT secret for signing user authentication tokens.
# CHANGE THIS to a long random string in production.
# Generate one: openssl rand -hex 64
JWT_SECRET=dev-jwt-secret-change-me-in-production-use-openssl-rand-hex-64

# API key that clients must send in the x-api-key header.
# CHANGE THIS to a secure random string.
# Generate one: openssl rand -hex 32
API_KEY=dev-api-key-change-me

# -----------------------------------------------------------------------------
# reCAPTCHA (Optional — leave empty to disable)
# -----------------------------------------------------------------------------
# Get keys at: https://www.google.com/recaptcha/admin
# Used to prevent spam when creating locations.
# Leave blank to skip reCAPTCHA validation (useful for self-hosted instances).
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# AWS S3 Photo Storage (Optional — leave empty to disable)
# -----------------------------------------------------------------------------
# Used for storing location photos.
# If not configured, photo uploads will be disabled.
# Create an S3 bucket and IAM user with S3 permissions.
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Email via Postmark (Optional — leave empty to disable)
# -----------------------------------------------------------------------------
# Used for user registration confirmation emails, password resets, etc.
# If not configured, email features will be disabled.
# Get a token at: https://postmarkapp.com
POSTMARK_API_TOKEN=
EMAIL_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Maximum number of locations returned per request (default: 1000)
MAX_LIMIT=1000

# Enable verbose SQL query logging (set to 'true' for debugging)
LOG_QUERIES=false

# Allowed CORS origins (comma-separated, or * for all)
# Example: http://localhost:3000,https://myapp.com
CORS_ORIGIN=*
